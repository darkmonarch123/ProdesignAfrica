#!/bin/sh
set -e

MAVEN_VERSION=3.9.9
DIR="$(cd "$(dirname "$0")" && pwd)"
WRAPPER_DIR="$DIR/.mvn/wrapper"
MAVEN_HOME_DIR="$DIR/.mvn/maven-$MAVEN_VERSION"
MAVEN_ZIP="$WRAPPER_DIR/apache-maven-$MAVEN_VERSION-bin.zip"
MAVEN_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/$MAVEN_VERSION/apache-maven-$MAVEN_VERSION-bin.zip"

if [ ! -x "$MAVEN_HOME_DIR/bin/mvn" ]; then
  echo "Maven not found locally — downloading Maven $MAVEN_VERSION (one-time setup)..."
  mkdir -p "$WRAPPER_DIR"
  curl -fsSL -o "$MAVEN_ZIP" "$MAVEN_URL"
  unzip -q -o "$MAVEN_ZIP" -d "$DIR/.mvn"
  mv "$DIR/.mvn/apache-maven-$MAVEN_VERSION" "$MAVEN_HOME_DIR"
  rm "$MAVEN_ZIP"
  echo "Maven installed locally in .mvn/maven-$MAVEN_VERSION"
fi

exec "$MAVEN_HOME_DIR/bin/mvn" "$@"
